# LiveKit (Cloud or self-hosted)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxx
LIVEKIT_API_SECRET=secretxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini Developer API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Cartesia TTS (https://play.cartesia.ai)
CARTESIA_API_KEY=

# Optional tuning
DEBATE_MODEL=gemini-2.5-flash
FACTCHECK_HALLUCINATION_THRESHOLD=0.8
ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=8000
WEB_ORIGIN=http://localhost:5173
